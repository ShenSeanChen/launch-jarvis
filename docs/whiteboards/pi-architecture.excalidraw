   "isDeleted": false,
   "boundElements": [],
   "updated": 1752700000000,
   "link": null,
   "locked": false,
   "text": "37 providers (Anthropic, OpenAI, Google, Groq,\nOpenRouter, DeepSeek, MiniMax, Kimi, ...)\n        \u2193  collapse onto  \u2193\n11 wire-format adapters (a provider = just data)\n\nContext is plain JSON \u2192 swap providers MID-SESSION",
   "fontSize": 14,
   "fontFamily": 1,
   "textAlign": "left",
   "verticalAlign": "top",
