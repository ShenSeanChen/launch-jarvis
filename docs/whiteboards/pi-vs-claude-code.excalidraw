      "boundElements": [],
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "honest ink: \"minimal\" doesn't delete complexity \u2014 pi relocates it to 2,100+ community packages. trust moves to third parties, it doesn't vanish.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
